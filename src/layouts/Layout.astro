---
import '../styles/global.css';
import HybridDocSearch from '../components/HybridDocSearch';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Get help with ChoreHero — setup, child access, chores, rewards, billing, and troubleshooting.',
  ogImage = '/img/parent-dashboard.png',
} = Astro.props;

const fullTitle = title === 'Help Center'
  ? 'ChoreHero Help Center'
  : `${title} — ChoreHero Help`;

const navLinks = [
  { href: '/docs/getting-started', label: 'Getting started' },
  { href: '/docs/parent-faqs', label: 'Parent FAQs' },
  { href: '/docs/billing-subscriptions', label: 'Billing' },
  { href: '/docs/troubleshooting', label: 'Troubleshooting' },
];

const footerCols = [
  {
    heading: 'Support',
    links: [
      { label: 'Getting started', href: '/docs/getting-started' },
      { label: 'Parent FAQs', href: '/docs/parent-faqs' },
      { label: 'Contact and support', href: '/docs/contact-support' },
    ],
  },
  {
    heading: 'Product',
    links: [
      { label: 'Open app', href: 'https://app.chorehero.cloud/login' },
      { label: 'Marketing site', href: 'https://chorehero.cloud' },
    ],
  },
  {
    heading: 'Legal',
    links: [
      { label: 'Privacy policy', href: 'https://app.chorehero.cloud/privacy-policy' },
      { label: 'Terms of use', href: 'https://app.chorehero.cloud/terms-of-use' },
    ],
  },
];

const sentryEnabled = import.meta.env.PUBLIC_SENTRY_ENABLED === 'true';
const sentryDsn = import.meta.env.PUBLIC_SENTRY_DSN ?? '';
const sentryEnvironment = import.meta.env.PUBLIC_SENTRY_ENVIRONMENT ?? 'production';
const sentryTracesSampleRate = Number(import.meta.env.PUBLIC_SENTRY_TRACES_SAMPLE_RATE ?? '0.1');
const enableSentry = sentryEnabled && sentryDsn.length > 0;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/img/logo-wordmark.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800;900&family=Sora:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    {enableSentry && (
      <script src="https://browser.sentry-cdn.com/10.22.0/bundle.min.js" crossorigin="anonymous"></script>
    )}
    {enableSentry && (
      <script define:vars={{ sentryDsn, sentryEnvironment, sentryTracesSampleRate }}>
        const ignoreSentryPatterns = [
          /^CHOREHERO_(?:CONSOLE|RUNTIME)_ERROR_TEST_/i,
          /Lock broken by another request with the 'steal' option\./i,
        ];
        const dynamicImportFailurePatterns = [
          /Failed to fetch dynamically imported module/i,
          /Importing a module script failed/i,
          /error loading dynamically imported module/i,
          /Unable to preload CSS/i,
        ];
        const dynamicImportReloadKey = '__chorehero_dynamic_import_reload__';
        const dynamicImportReloadWindowMs = 15000;

        const collectErrorTexts = (value, target = []) => {
          if (!value) return target;

          if (typeof value === 'string') {
            const normalized = value.trim();
            if (normalized) target.push(normalized);
            return target;
          }

          if (value instanceof Error) {
            collectErrorTexts(value.name, target);
            collectErrorTexts(value.message, target);
          }

          if (Array.isArray(value)) {
            value.forEach((entry) => collectErrorTexts(entry, target));
            return target;
          }

          collectErrorTexts(value.message, target);
          collectErrorTexts(value.name, target);
          collectErrorTexts(value.type, target);
          collectErrorTexts(value.reason, target);
          collectErrorTexts(value.formatted, target);
          collectErrorTexts(value.value, target);

          if (Array.isArray(value.exception?.values)) {
            value.exception.values.forEach((entry) => collectErrorTexts(entry, target));
          }

          if (value.logentry) {
            collectErrorTexts(value.logentry, target);
          }

          return target;
        };

        const matchesPatterns = (value, patterns) =>
          collectErrorTexts(value).some((text) => patterns.some((pattern) => pattern.test(text)));

        const shouldIgnoreSentryValue = (value) => matchesPatterns(value, ignoreSentryPatterns);
        const shouldIgnoreSentryEvent = (event, hint) =>
          shouldIgnoreSentryValue(event) ||
          shouldIgnoreSentryValue(hint?.originalException) ||
          shouldIgnoreSentryValue(hint?.syntheticException);

        const recoverFromDynamicImportFailure = (value) => {
          if (!matchesPatterns(value, dynamicImportFailurePatterns)) return false;

          try {
            const now = Date.now();
            const currentHref = window.location.href;
            const previousRaw = window.sessionStorage.getItem(dynamicImportReloadKey);
            const previous = previousRaw ? JSON.parse(previousRaw) : null;
            const retriedRecently =
              previous?.href === currentHref &&
              now - Number(previous?.at || 0) < dynamicImportReloadWindowMs;

            if (retriedRecently) return false;

            window.sessionStorage.setItem(
              dynamicImportReloadKey,
              JSON.stringify({ href: currentHref, at: now })
            );
            window.location.reload();
            return true;
          } catch {
            return false;
          }
        };

        const consoleIntegration =
          typeof window.Sentry?.captureConsoleIntegration === 'function'
            ? window.Sentry.captureConsoleIntegration({
                levels: ['error', 'warn', 'assert'],
              })
            : typeof window.Sentry?.Integrations?.CaptureConsole === 'function'
              ? new window.Sentry.Integrations.CaptureConsole({
                  levels: ['error', 'warn', 'assert'],
                })
              : null;

        window.Sentry?.init({
          dsn: sentryDsn,
          environment: sentryEnvironment,
          integrations: consoleIntegration ? [consoleIntegration] : [],
          tracesSampleRate: Number.isFinite(sentryTracesSampleRate) ? sentryTracesSampleRate : 0.1,
          ignoreErrors: ignoreSentryPatterns,
          beforeSend(event, hint) {
            if (shouldIgnoreSentryEvent(event, hint)) {
              return null;
            }
            return event;
          },
        });

        window.addEventListener('vite:preloadError', (event) => {
          const payload = event?.payload ?? event?.detail ?? event?.error ?? null;
          if (recoverFromDynamicImportFailure(payload)) {
            event.preventDefault?.();
          }
        });

        if (!consoleIntegration && window.Sentry) {
          const originalConsoleError = console.error.bind(console);
          const originalConsoleWarn = console.warn.bind(console);
          const originalConsoleAssert = console.assert.bind(console);
          let isCapturing = false;

          const normalizeArg = (value) => {
            if (value instanceof Error) return value.message;
            if (typeof value === 'string') return value;
            try {
              return JSON.stringify(value);
            } catch {
              return String(value);
            }
          };

          const captureConsoleEvent = (level, args) => {
            if (isCapturing) return;
            if (shouldIgnoreSentryValue(args)) return;
            isCapturing = true;
            try {
              const errorArg = args.find((arg) => arg instanceof Error);
              const normalizedArgs = args.map(normalizeArg).join(' ');

              if (errorArg) {
                window.Sentry.captureException(errorArg, {
                  level,
                  extra: { console_args: normalizedArgs },
                });
              } else {
                window.Sentry.captureMessage(normalizedArgs || 'Console message', {
                  level,
                });
              }
            } finally {
              isCapturing = false;
            }
          };

          console.error = (...args) => {
            captureConsoleEvent('error', args);
            originalConsoleError(...args);
          };

          console.warn = (...args) => {
            captureConsoleEvent('warning', args);
            originalConsoleWarn(...args);
          };

          console.assert = (condition, ...args) => {
            if (!condition) {
              captureConsoleEvent('error', ['Assertion failed', ...args]);
            }
            originalConsoleAssert(condition, ...args);
          };
        }

        if (window.Sentry && !window.__choreHeroSentryGlobalHandlersInstalled) {
          window.__choreHeroSentryGlobalHandlersInstalled = true;

          window.addEventListener('error', (event) => {
            const errorValue = event?.error || event?.message || 'Uncaught browser error';
            if (recoverFromDynamicImportFailure(errorValue) || shouldIgnoreSentryValue(errorValue)) {
              return;
            }

            const error = event?.error instanceof Error
              ? event.error
              : new Error(event?.message || 'Uncaught browser error');

            window.Sentry.captureException(error, {
              level: 'error',
              extra: {
                source: 'window.error',
                filename: event?.filename || null,
                lineno: event?.lineno || null,
                colno: event?.colno || null,
              },
            });
          });

          window.addEventListener('unhandledrejection', (event) => {
            const reason = event?.reason;
            if (recoverFromDynamicImportFailure(reason) || shouldIgnoreSentryValue(reason)) {
              return;
            }

            const error = reason instanceof Error
              ? reason
              : new Error(typeof reason === 'string' ? reason : 'Unhandled promise rejection');

            window.Sentry.captureException(error, {
              level: 'error',
              extra: {
                source: 'window.unhandledrejection',
                reason: reason && !(reason instanceof Error)
                  ? (() => {
                      try {
                        return JSON.stringify(reason);
                      } catch {
                        return String(reason);
                      }
                    })()
                  : null,
              },
            });
          });
        }
      </script>
    )}
  </head>
  <body class="font-body text-ink antialiased min-h-screen">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:rounded-full focus:shadow-soft focus:text-ink text-sm font-semibold"
    >
      Skip to main content
    </a>

    <!-- Navbar -->
    <header class="sticky top-0 z-40 w-full bg-white/90 backdrop-blur-md border-b border-blue-950/[0.07] shadow-[0_1px_12px_rgba(37,72,140,0.06)]">
      <div class="max-w-site mx-auto px-4 sm:px-6 h-14 flex items-center gap-3">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 min-w-0 shrink-0">
          <img src="/img/logo-wordmark.png" alt="ChoreHero" class="h-8 w-auto" loading="eager" />
          <span class="hidden sm:flex flex-col leading-none">
            <strong class="font-display font-bold text-[1.1rem] tracking-tight text-ink">ChoreHero</strong>
            <span class="text-cobalt text-[0.68rem] font-bold tracking-[0.06em] mt-0.5">Help Center</span>
          </span>
        </a>

        <!-- Nav links (desktop) -->
        <nav class="hidden md:flex items-center gap-0.5 ml-6" aria-label="Help navigation">
          {navLinks.map(link => (
            <a
              href={link.href}
              class="px-3 py-1.5 text-[0.88rem] font-semibold text-ink/60 rounded-lg hover:bg-brand/[0.06] hover:text-cobalt transition-colors duration-150"
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Right: search + CTA -->
        <div class="ml-auto flex items-center gap-2.5">
          <HybridDocSearch client:load />
          <a
            href="https://app.chorehero.cloud/login"
            class="hidden sm:flex flex-none px-4 py-2 rounded-full bg-cobalt text-white font-bold text-[0.85rem] tracking-wide shadow-[0_4px_14px_rgba(37,99,235,0.26)] hover:bg-blue-700 hover:shadow-[0_6px_20px_rgba(37,99,235,0.32)] transition-all duration-200"
          >
            Open app
          </a>
        </div>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-20 border-t border-blue-950/[0.07] bg-ink text-white/80">
      <div class="max-w-site mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mb-10">
          {footerCols.map(col => (
            <div>
              <p class="text-[0.7rem] font-black tracking-[0.18em] uppercase text-white/40 mb-3">{col.heading}</p>
              <ul class="space-y-2">
                {col.links.map(l => (
                  <li>
                    <a href={l.href} class="text-[0.9rem] text-white/60 hover:text-white transition-colors">
                      {l.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div class="pt-6 border-t border-white/[0.08] flex flex-col sm:flex-row items-center justify-between gap-3">
          <div class="flex items-center gap-2.5">
            <img src="/img/logo-wordmark-white.png" alt="ChoreHero" class="h-6 w-auto opacity-60" loading="lazy" />
            <span class="font-display font-bold text-[0.95rem] text-white/50">ChoreHero</span>
          </div>
          <p class="text-[0.8rem] text-white/35">© {new Date().getFullYear()} ChoreHero. All rights reserved.</p>
          <a href="https://chorehero.cloud" class="text-[0.85rem] text-white/40 hover:text-white/70 transition-colors">chorehero.cloud</a>
        </div>
      </div>
    </footer>
  </body>
</html>
