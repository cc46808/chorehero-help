---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  currentSlug: string;
}

const { title, description, currentSlug } = Astro.props;

const sidebarItems = [
  { slug: 'intro', label: 'Overview' },
  { slug: 'getting-started', label: 'Getting started' },
  { slug: 'parent-faqs', label: 'Parent FAQs' },
  { slug: 'billing-subscriptions', label: 'Billing and subscriptions' },
  { slug: 'account-login-onboarding', label: 'Account and login' },
  { slug: 'chores-rewards-basics', label: 'Chores and rewards' },
  { slug: 'troubleshooting', label: 'Troubleshooting' },
  { slug: 'contact-support', label: 'Contact and support' },
  { slug: 'authoring-guide', label: 'Authoring guide' },
];
---

<Layout title={title} description={description}>
  <div class="max-w-site mx-auto px-4 sm:px-6 py-8 md:py-12">
    <div class="flex flex-col md:flex-row gap-8 lg:gap-12 items-start">

      <!-- Sidebar -->
      <aside class="w-full md:w-56 lg:w-64 shrink-0">
        <nav class="md:sticky md:top-20" aria-label="Docs navigation">
          <p class="eyebrow mb-3 px-3">Documentation</p>
          <ul class="space-y-0.5">
            {sidebarItems.map(item => {
              const isActive = item.slug === currentSlug;
              return (
                <li>
                  <a
                    href={`/docs/${item.slug}`}
                    class:list={[
                      'flex items-center px-3 py-2 rounded-lg text-[0.9rem] font-medium transition-colors duration-150',
                      isActive
                        ? 'bg-brand/[0.08] text-cobalt font-semibold'
                        : 'text-ink/65 hover:bg-brand/[0.05] hover:text-cobalt',
                    ]}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </aside>

      <!-- Doc content -->
      <article class="min-w-0 flex-1">
        <div class="section-card px-6 sm:px-10 py-8 sm:py-12">
          <div
            class="prose prose-lg max-w-none
              prose-headings:font-display prose-headings:text-ink
              prose-a:text-cobalt hover:prose-a:text-brand
              prose-code:text-brand prose-code:bg-brand/[0.08] prose-code:rounded prose-code:px-1.5 prose-code:py-0.5
              prose-code:before:content-none prose-code:after:content-none
              prose-pre:bg-paper prose-pre:border prose-pre:border-blue-950/[0.07]"
          >
            <slot />
          </div>
        </div>
      </article>

    </div>
  </div>
</Layout>
