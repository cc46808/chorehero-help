---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  currentSlug: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { title, description, currentSlug, headings = [] } = Astro.props;
const pageAnchors = headings.filter(heading => heading.depth === 2 || heading.depth === 3);

const sidebarItems = [
  { slug: 'intro', label: 'Overview' },
  { slug: 'getting-started', label: 'Getting started' },
  { slug: 'parent-faqs', label: 'Parent FAQs' },
  { slug: 'billing-subscriptions', label: 'Billing and subscriptions' },
  { slug: 'account-login-onboarding', label: 'Account and login' },
  { slug: 'chores-rewards-basics', label: 'Chores and rewards' },
  { slug: 'troubleshooting', label: 'Troubleshooting' },
  { slug: 'contact-support', label: 'Contact and support' },
];
---

<Layout title={title} description={description}>
  <div class="max-w-site mx-auto px-4 sm:px-6 py-8 md:py-12">
    <div class="flex flex-col md:flex-row gap-8 lg:gap-12 items-start">

      <!-- Sidebar -->
      <aside class="w-full md:w-56 lg:w-64 shrink-0 md:sticky md:top-20 self-start">
        <nav aria-label="Docs navigation">
          <p class="eyebrow mb-3 px-3">Documentation</p>
          <ul class="space-y-0.5">
            {sidebarItems.map(item => {
              const isActive = item.slug === currentSlug;
              return (
                <li>
                  <a
                    href={`/docs/${item.slug}`}
                    class:list={[
                      'flex items-center px-3 py-2 rounded-lg text-[0.9rem] font-medium transition-colors duration-150',
                      isActive
                        ? 'bg-brand/[0.08] text-cobalt font-semibold'
                        : 'text-ink/65 hover:bg-brand/[0.05] hover:text-cobalt',
                    ]}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </aside>

      <!-- Doc content -->
      <article class="min-w-0 flex-1">
        <div class="section-card px-6 sm:px-10 py-8 sm:py-12">
          <div
            class="prose prose-lg max-w-none
              prose-headings:font-display prose-headings:text-ink
              prose-a:text-cobalt hover:prose-a:text-brand
              prose-code:text-brand prose-code:bg-brand/[0.08] prose-code:rounded prose-code:px-1.5 prose-code:py-0.5
              prose-code:before:content-none prose-code:after:content-none
              prose-pre:bg-paper prose-pre:border prose-pre:border-blue-950/[0.07]"
          >
            <slot />
          </div>
        </div>
      </article>

      <!-- Right-side page anchors -->
      <aside class="hidden lg:block w-56 shrink-0 md:sticky md:top-20 self-start">
        <nav aria-label="On this page">
          <p class="eyebrow mb-3 px-3">On this page</p>
          {pageAnchors.length > 0 ? (
            <ul class="space-y-0.5">
              {pageAnchors.map(anchor => (
                <li>
                  <a
                    href={`#${anchor.slug}`}
                    data-anchor-link
                    data-anchor-slug={anchor.slug}
                    class:list={[
                      'toc-link flex items-center rounded-lg px-3 py-1.5 text-[0.84rem] font-medium transition-colors duration-150',
                      anchor.depth === 3
                        ? 'toc-link-sub pl-6 text-ink/55 hover:bg-brand/[0.04] hover:text-cobalt'
                        : 'text-ink/65 hover:bg-brand/[0.05] hover:text-cobalt',
                    ]}
                  >
                    {anchor.text}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="px-3 text-[0.82rem] text-ink/50">No section anchors on this page.</p>
          )}
        </nav>
      </aside>

    </div>
  </div>
</Layout>

<script is:inline>
  (() => {
    const links = Array.from(document.querySelectorAll('[data-anchor-link]'));
    if (!links.length) return;

    const targets = links
      .map(link => {
        const slug = link.getAttribute('data-anchor-slug');
        if (!slug) return null;
        const section = document.getElementById(slug);
        if (!section) return null;
        return { slug, link, section };
      })
      .filter(Boolean);

    if (!targets.length) return;

    const topOffset = 96;
    const visibleSlugs = new Set();
    let activeSlug = null;

    const setActive = slug => {
      if (!slug || slug === activeSlug) return;
      activeSlug = slug;

      for (const item of targets) {
        const isActive = item.slug === slug;
        item.link.classList.toggle('is-active', isActive);
        if (isActive) {
          item.link.setAttribute('aria-current', 'location');
        } else {
          item.link.removeAttribute('aria-current');
        }
      }
    };

    const pickByScrollPosition = () => {
      let candidate = targets[0].slug;
      for (const item of targets) {
        if (item.section.getBoundingClientRect().top - topOffset <= 0) {
          candidate = item.slug;
        } else {
          break;
        }
      }
      return candidate;
    };

    const refreshActive = () => {
      if (visibleSlugs.size) {
        const visibleOrdered = targets.filter(item => visibleSlugs.has(item.slug));
        if (visibleOrdered.length) {
          setActive(visibleOrdered[0].slug);
          return;
        }
      }
      setActive(pickByScrollPosition());
    };

    const observer = new IntersectionObserver(
      entries => {
        for (const entry of entries) {
          const slug = entry.target.id;
          if (!slug) continue;
          if (entry.isIntersecting) {
            visibleSlugs.add(slug);
          } else {
            visibleSlugs.delete(slug);
          }
        }
        refreshActive();
      },
      {
        rootMargin: '-96px 0px -60% 0px',
        threshold: [0, 1],
      }
    );

    for (const item of targets) {
      observer.observe(item.section);
    }

    window.addEventListener('scroll', refreshActive, { passive: true });
    window.addEventListener('hashchange', () => {
      const hash = window.location.hash ? window.location.hash.slice(1) : '';
      if (hash) setActive(hash);
    });

    const initialHash = window.location.hash ? window.location.hash.slice(1) : '';
    if (initialHash && targets.some(item => item.slug === initialHash)) {
      setActive(initialHash);
    } else {
      refreshActive();
    }
  })();
</script>

<style>
  :global(.prose h2),
  :global(.prose h3) {
    scroll-margin-top: 6.5rem;
  }

  .toc-link.is-active {
    background: rgba(49, 83, 164, 0.1);
    color: #2563eb;
    font-weight: 700;
  }

  .toc-link.toc-link-sub.is-active {
    background: rgba(49, 83, 164, 0.08);
    color: #3153a4;
    font-weight: 600;
  }
</style>
