---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description?: string;
  currentSlug: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { title, description, currentSlug, headings = [] } = Astro.props;
const pageAnchors = headings.filter(heading => heading.depth === 2 || heading.depth === 3);

const sidebarItems = [
  { slug: 'intro', label: 'Overview' },
  { slug: 'getting-started', label: 'Getting started' },
  { slug: 'managing-heroes', label: 'Managing heroes' },
  { slug: 'creating-chores', label: 'Creating chores' },
  { slug: 'setting-up-rewards', label: 'Setting up rewards' },
  { slug: 'understanding-achievements', label: 'Understanding achievements' },
  { slug: 'chores-rewards-basics', label: 'Chores and rewards basics' },
  { slug: 'parent-faqs', label: 'Parent FAQs' },
  { slug: 'billing-subscriptions', label: 'Billing and subscriptions' },
  { slug: 'account-login-onboarding', label: 'Account and login' },
  { slug: 'troubleshooting', label: 'Troubleshooting' },
  { slug: 'contact-support', label: 'Contact and support' },
];
---

<Layout title={title} description={description}>
  <div class="max-w-site mx-auto px-4 sm:px-6 py-8 md:py-12">
    <div class="flex flex-col md:flex-row gap-8 lg:gap-12 items-start">

      <!-- Sidebar -->
      <aside class="w-full md:w-56 lg:w-64 shrink-0 md:sticky md:top-20 self-start">
        <nav aria-label="Docs navigation">
          <p class="eyebrow mb-3 px-3">Documentation</p>
          <ul class="space-y-0.5">
            {sidebarItems.map(item => {
              const isActive = item.slug === currentSlug;
              return (
                <li>
                  <a
                    href={`/docs/${item.slug}`}
                    class:list={[
                      'flex items-center px-3 py-2 rounded-lg text-[0.9rem] font-medium transition-colors duration-150',
                      isActive
                        ? 'bg-brand/[0.08] text-cobalt font-semibold'
                        : 'text-ink/65 hover:bg-brand/[0.05] hover:text-cobalt',
                    ]}
                    aria-current={isActive ? 'page' : undefined}
                  >
                    {item.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </aside>

      <!-- Doc content -->
      <article class="min-w-0 flex-1">
        <div class="section-card px-6 sm:px-10 py-8 sm:py-12">
          <div
            class="prose prose-lg max-w-none
              prose-headings:font-display prose-headings:text-ink
              prose-a:text-cobalt hover:prose-a:text-brand
              prose-code:text-brand prose-code:bg-brand/[0.08] prose-code:rounded prose-code:px-1.5 prose-code:py-0.5
              prose-code:before:content-none prose-code:after:content-none
              prose-pre:bg-paper prose-pre:border prose-pre:border-blue-950/[0.07]"
          >
            <slot />
          </div>
        </div>
      </article>

      <!-- Right-side page anchors -->
      <aside class="hidden lg:block w-56 shrink-0 md:sticky md:top-20 self-start">
        <nav aria-label="On this page">
          <p class="eyebrow mb-3 px-3">On this page</p>
          {pageAnchors.length > 0 ? (
            <ul class="space-y-0.5">
              {pageAnchors.map(anchor => (
                <li>
                  <a
                    href={`#${anchor.slug}`}
                    data-anchor-link
                    data-anchor-slug={anchor.slug}
                    class:list={[
                      'toc-link flex items-center rounded-lg px-3 py-1.5 text-[0.84rem] font-medium transition-colors duration-150',
                      anchor.depth === 3
                        ? 'toc-link-sub pl-6 text-ink/55 hover:bg-brand/[0.04] hover:text-cobalt'
                        : 'text-ink/65 hover:bg-brand/[0.05] hover:text-cobalt',
                    ]}
                  >
                    {anchor.text}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="px-3 text-[0.82rem] text-ink/50">No section anchors on this page.</p>
          )}
        </nav>
      </aside>

    </div>
  </div>
</Layout>

<script is:inline>
  (() => {
    const links = Array.from(document.querySelectorAll('[data-anchor-link]'));
    if (!links.length) return;

    const targets = links
      .map(link => {
        const slug = link.getAttribute('data-anchor-slug');
        if (!slug) return null;
        const section = document.getElementById(slug);
        if (!section) return null;
        return { slug, link, section };
      })
      .filter(Boolean);

    if (!targets.length) return;

    const topOffset = 96;
    const visibleSlugs = new Set();
    let activeSlug = null;

    const setActive = slug => {
      if (!slug || slug === activeSlug) return;
      activeSlug = slug;

      for (const item of targets) {
        const isActive = item.slug === slug;
        item.link.classList.toggle('is-active', isActive);
        if (isActive) {
          item.link.setAttribute('aria-current', 'location');
        } else {
          item.link.removeAttribute('aria-current');
        }
      }
    };

    const pickByScrollPosition = () => {
      let candidate = targets[0].slug;
      for (const item of targets) {
        if (item.section.getBoundingClientRect().top - topOffset <= 0) {
          candidate = item.slug;
        } else {
          break;
        }
      }
      return candidate;
    };

    const refreshActive = () => {
      if (visibleSlugs.size) {
        const visibleOrdered = targets.filter(item => visibleSlugs.has(item.slug));
        if (visibleOrdered.length) {
          setActive(visibleOrdered[0].slug);
          return;
        }
      }
      setActive(pickByScrollPosition());
    };

    const observer = new IntersectionObserver(
      entries => {
        for (const entry of entries) {
          const slug = entry.target.id;
          if (!slug) continue;
          if (entry.isIntersecting) {
            visibleSlugs.add(slug);
          } else {
            visibleSlugs.delete(slug);
          }
        }
        refreshActive();
      },
      {
        rootMargin: '-96px 0px -60% 0px',
        threshold: [0, 1],
      }
    );

    for (const item of targets) {
      observer.observe(item.section);
    }

    window.addEventListener('scroll', refreshActive, { passive: true });
    window.addEventListener('hashchange', () => {
      const hash = window.location.hash ? window.location.hash.slice(1) : '';
      if (hash) setActive(hash);
    });

    const initialHash = window.location.hash ? window.location.hash.slice(1) : '';
    if (initialHash && targets.some(item => item.slug === initialHash)) {
      setActive(initialHash);
    } else {
      refreshActive();
    }
  })();

  (() => {
    const contentRoot = document.querySelector('.prose');
    if (!contentRoot) return;

    const images = Array.from(contentRoot.querySelectorAll('img'));
    if (!images.length) return;

    const dialog = document.createElement('dialog');
    dialog.className = 'doc-image-lightbox';
    dialog.innerHTML = `
      <button type="button" class="doc-image-lightbox-close" aria-label="Close image">Close</button>
      <div class="doc-image-lightbox-frame">
        <button type="button" class="doc-image-lightbox-nav doc-image-lightbox-prev" aria-label="Previous image" hidden>Previous</button>
        <img class="doc-image-lightbox-media" alt="" />
        <button type="button" class="doc-image-lightbox-nav doc-image-lightbox-next" aria-label="Next image" hidden>Next</button>
      </div>
      <div class="doc-image-lightbox-footer">
        <p class="doc-image-lightbox-caption" aria-live="polite"></p>
        <p class="doc-image-lightbox-counter" aria-live="polite"></p>
      </div>
    `;

    document.body.appendChild(dialog);

    const dialogImage = dialog.querySelector('.doc-image-lightbox-media');
    const dialogCaption = dialog.querySelector('.doc-image-lightbox-caption');
    const dialogCounter = dialog.querySelector('.doc-image-lightbox-counter');
    const closeButton = dialog.querySelector('.doc-image-lightbox-close');
    const previousButton = dialog.querySelector('.doc-image-lightbox-prev');
    const nextButton = dialog.querySelector('.doc-image-lightbox-next');
    const galleryFigures = Array.from(contentRoot.querySelectorAll('.doc-image-gallery'));

    let activeItems = [];
    let activeIndex = 0;

    const closeDialog = () => {
      if (dialog.open) dialog.close();
    };

    const setActiveSlide = nextIndex => {
      if (!dialogImage || !activeItems.length) return;
      activeIndex = Math.max(0, Math.min(nextIndex, activeItems.length - 1));
      const item = activeItems[activeIndex];
      dialogImage.src = item.src;
      dialogImage.alt = item.alt || 'Documentation image';
      if (dialogCaption) {
        dialogCaption.textContent = item.alt || '';
      }
      if (dialogCounter) {
        dialogCounter.textContent =
          activeItems.length > 1 ? `${activeIndex + 1} of ${activeItems.length}` : '';
        dialogCounter.hidden = activeItems.length <= 1;
      }
      if (previousButton) {
        previousButton.hidden = activeItems.length <= 1;
        previousButton.disabled = activeIndex === 0;
      }
      if (nextButton) {
        nextButton.hidden = activeItems.length <= 1;
        nextButton.disabled = activeIndex === activeItems.length - 1;
      }
    };

    const openDialog = items => {
      if (!items.length) return;
      activeItems = items;
      setActiveSlide(0);
      if (!dialog.open) dialog.showModal();
    };

    const getImageItems = image => {
      const galleryFigure = image.closest('.doc-image-gallery');
      if (!galleryFigure) {
        return [
          {
            src: image.currentSrc || image.src,
            alt: image.alt || 'Documentation image',
          },
        ];
      }

      const galleryItems = Array.from(galleryFigure.querySelectorAll('[data-doc-gallery-item]'))
        .map(item => {
          if (!(item instanceof HTMLAnchorElement)) return null;
          return {
            src: item.href,
            alt: item.dataset.alt || image.alt || 'Documentation image',
          };
        })
        .filter(Boolean);

      return galleryItems.length
        ? galleryItems
        : [
            {
              src: image.currentSrc || image.src,
              alt: image.alt || 'Documentation image',
            },
          ];
    };

    galleryFigures.forEach(figure => {
      const previewImage = figure.querySelector('img');
      const galleryCount = figure.querySelectorAll('[data-doc-gallery-item]').length;
      if (!(previewImage instanceof HTMLImageElement) || galleryCount <= 1) return;

      figure.classList.add('doc-image-gallery--multi');
      if (!figure.querySelector('.doc-image-gallery-badge')) {
        const badge = document.createElement('span');
        badge.className = 'doc-image-gallery-badge';
        badge.setAttribute('aria-hidden', 'true');
        badge.textContent = `View ${galleryCount} images`;
        figure.appendChild(badge);
      }
    });

    closeButton?.addEventListener('click', closeDialog);
    previousButton?.addEventListener('click', () => setActiveSlide(activeIndex - 1));
    nextButton?.addEventListener('click', () => setActiveSlide(activeIndex + 1));

    dialog.addEventListener('click', event => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (target === dialog) closeDialog();
    });

    dialog.addEventListener('keydown', event => {
      if (!dialog.open || activeItems.length <= 1) return;
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        setActiveSlide(activeIndex - 1);
      }
      if (event.key === 'ArrowRight') {
        event.preventDefault();
        setActiveSlide(activeIndex + 1);
      }
    });

    images.forEach(image => {
      image.classList.add('doc-zoomable-image');
      image.setAttribute('role', 'button');
      image.setAttribute('tabindex', '0');
      const items = getImageItems(image);
      const isGallery = items.length > 1;
      image.setAttribute(
        'aria-label',
        isGallery
          ? `Open image gallery: ${image.alt || 'Documentation image'} (${items.length} images)`
          : `Open image: ${image.alt || 'Documentation image'}`
      );

      image.addEventListener('click', () => openDialog(items));
      image.addEventListener('keydown', event => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openDialog(items);
        }
      });
    });
  })();
</script>

<style>
  :global(.prose h2),
  :global(.prose h3) {
    scroll-margin-top: 6.5rem;
  }

  .toc-link.is-active {
    background: rgba(49, 83, 164, 0.1);
    color: #2563eb;
    font-weight: 700;
  }

  .toc-link.toc-link-sub.is-active {
    background: rgba(49, 83, 164, 0.08);
    color: #3153a4;
    font-weight: 600;
  }

  :global(.prose .doc-zoomable-image) {
    cursor: zoom-in;
    transition: transform 140ms ease, box-shadow 140ms ease;
  }

  :global(.prose .doc-zoomable-image:hover) {
    transform: translateY(-1px);
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.12);
  }

  :global(.prose figure.doc-image-gallery) {
    position: relative;
    width: fit-content;
  }

  :global(.prose figure.doc-image-gallery .doc-zoomable-image) {
    margin-bottom: 0;
  }

  :global(.prose .doc-image-gallery-badge) {
    position: absolute;
    right: 0.85rem;
    bottom: 0.85rem;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.82);
    color: #f8fafc;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    padding: 0.38rem 0.72rem;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.18);
  }

  :global(dialog.doc-image-lightbox) {
    border: none;
    border-radius: 14px;
    padding: 0;
    width: min(94vw, 1180px);
    background: #f8fafc;
    box-shadow: 0 26px 72px rgba(2, 6, 23, 0.45);
  }

  :global(dialog.doc-image-lightbox::backdrop) {
    background: rgba(2, 6, 23, 0.68);
  }

  :global(.doc-image-lightbox-close) {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    border: 1px solid rgba(15, 23, 42, 0.2);
    border-radius: 10px;
    background: rgba(248, 250, 252, 0.95);
    color: #0f172a;
    font-size: 0.84rem;
    font-weight: 600;
    padding: 0.45rem 0.7rem;
    cursor: pointer;
  }

  :global(.doc-image-lightbox-frame) {
    position: relative;
  }

  :global(.doc-image-lightbox-media) {
    display: block;
    max-width: 100%;
    max-height: min(82vh, 920px);
    margin: 0 auto;
    object-fit: contain;
    border-radius: 14px 14px 0 0;
  }

  :global(.doc-image-lightbox-nav) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    border: 1px solid rgba(15, 23, 42, 0.14);
    border-radius: 999px;
    background: rgba(248, 250, 252, 0.92);
    color: #0f172a;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.5rem 0.8rem;
    cursor: pointer;
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.15);
  }

  :global(.doc-image-lightbox-nav[hidden]) {
    display: none;
  }

  :global(.doc-image-lightbox-nav:disabled) {
    opacity: 0.45;
    cursor: default;
  }

  :global(.doc-image-lightbox-prev) {
    left: 14px;
  }

  :global(.doc-image-lightbox-next) {
    right: 14px;
  }

  :global(.doc-image-lightbox-footer) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    padding: 0.7rem 1rem 0.95rem;
  }

  :global(.doc-image-lightbox-caption) {
    margin: 0;
    font-size: 0.86rem;
    color: #334155;
    text-align: left;
    min-height: 1.8rem;
    flex: 1;
  }

  :global(.doc-image-lightbox-counter) {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    color: #475569;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    :global(.doc-image-gallery-badge) {
      right: 0.6rem;
      bottom: 0.6rem;
      font-size: 0.72rem;
      padding: 0.34rem 0.62rem;
    }

    :global(.doc-image-lightbox-nav) {
      top: auto;
      bottom: 12px;
      transform: none;
      padding: 0.42rem 0.7rem;
    }

    :global(.doc-image-lightbox-footer) {
      flex-direction: column;
      align-items: flex-start;
      padding-right: 4.5rem;
    }

    :global(.doc-image-lightbox-counter) {
      white-space: normal;
    }
  }
</style>
