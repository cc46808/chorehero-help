---
// ScreenshotViewer — replaces prose <img> tags with inline icon buttons.
// Hover the icon to preview a thumbnail; click to open a full-screen modal.
// Progressive enhancement: images render normally with JS disabled.
---

<style is:global>
  /* ── Icon trigger ─────────────────────────────────────────────────────── */

  .screenshot-trigger-para {
    margin: 1.5rem 0;
  }

  .screenshot-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    position: relative;
    padding: 0.3em 0.8em 0.3em 0.6em;
    border: 1.5px solid rgba(49, 83, 164, 0.22);
    border-radius: 100px;
    background: rgba(49, 83, 164, 0.05);
    color: #2563eb;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: 'Manrope', 'Avenir Next', 'Segoe UI', sans-serif;
    line-height: 1;
    cursor: pointer;
    vertical-align: middle;
    text-decoration: none !important;
    transition: background 0.15s, border-color 0.15s, box-shadow 0.15s, color 0.15s;
  }

  .screenshot-trigger:hover,
  .screenshot-trigger:focus-visible {
    background: rgba(49, 83, 164, 0.11);
    border-color: rgba(49, 83, 164, 0.44);
    box-shadow: 0 2px 10px rgba(49, 83, 164, 0.14);
    color: #3153a4;
    outline: none;
  }

  .screenshot-trigger-icon {
    width: 1.15em;
    height: 1.15em;
    flex-shrink: 0;
  }

  /* ── Hover popover ────────────────────────────────────────────────────── */

  .screenshot-popover {
    position: absolute;
    left: 50%;
    bottom: calc(100% + 10px);
    top: auto;
    transform: translateX(-50%);
    z-index: 1200;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.18s ease;
    filter: drop-shadow(0 10px 28px rgba(37, 72, 140, 0.18));
    /* Don't overflow off narrow viewports */
    max-width: min(280px, calc(100vw - 2rem));
  }

  /* Flip below when button is near the top (set via data-pop-below) */
  .screenshot-trigger[data-pop-below] .screenshot-popover {
    top: calc(100% + 10px);
    bottom: auto;
  }

  .screenshot-trigger[data-pop-open] .screenshot-popover {
    opacity: 1;
  }

  .screenshot-popover-inner {
    background: white;
    border: 1px solid rgba(37, 72, 140, 0.1);
    border-radius: 10px;
    padding: 6px;
    width: 280px;
    max-width: 100%;
  }

  .screenshot-popover-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px;
    object-fit: cover;
  }

  .screenshot-popover-caption {
    padding: 5px 4px 2px;
    font-size: 0.72rem;
    color: rgba(33, 48, 79, 0.55);
    font-family: 'Manrope', sans-serif;
    line-height: 1.3;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  /* ── Full-screen modal ────────────────────────────────────────────────── */

  #ch-screenshot-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(10, 22, 50, 0.86);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }

  #ch-screenshot-modal[data-open] {
    opacity: 1;
    pointer-events: all;
  }

  #ch-screenshot-modal-content {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: min(92vw, 1280px);
    max-height: 90vh;
    transform: scale(0.96);
    transition: transform 0.22s ease;
  }

  #ch-screenshot-modal[data-open] #ch-screenshot-modal-content {
    transform: scale(1);
  }

  #ch-screenshot-modal-img {
    max-width: 100%;
    max-height: 88vh;
    width: auto;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 32px 80px rgba(10, 22, 50, 0.6);
    object-fit: contain;
    display: block;
    user-select: none;
  }

  #ch-screenshot-modal-close {
    position: fixed;
    top: 1.25rem;
    right: 1.25rem;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.88);
    background: rgba(255, 255, 255, 0.12);
    border: 1.5px solid rgba(255, 255, 255, 0.18);
    border-radius: 50%;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: background 0.15s, color 0.15s;
  }

  #ch-screenshot-modal-close:hover,
  #ch-screenshot-modal-close:focus-visible {
    background: rgba(255, 255, 255, 0.22);
    color: white;
    outline: none;
  }

  #ch-screenshot-modal-caption {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.82rem;
    font-family: 'Manrope', sans-serif;
    text-align: center;
    pointer-events: none;
    max-width: 80vw;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>

<script>
  // ── Modal ─────────────────────────────────────────────────────────────────

  const modal = document.createElement('div');
  modal.id = 'ch-screenshot-modal';
  modal.setAttribute('role', 'dialog');
  modal.setAttribute('aria-modal', 'true');
  modal.setAttribute('aria-label', 'Screenshot preview');
  modal.tabIndex = -1;

  const closeBtn = document.createElement('button');
  closeBtn.id = 'ch-screenshot-modal-close';
  closeBtn.type = 'button';
  closeBtn.setAttribute('aria-label', 'Close screenshot');
  closeBtn.innerHTML =
    '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>';

  const content = document.createElement('div');
  content.id = 'ch-screenshot-modal-content';

  const modalImg = document.createElement('img');
  modalImg.id = 'ch-screenshot-modal-img';
  modalImg.alt = '';

  const caption = document.createElement('p');
  caption.id = 'ch-screenshot-modal-caption';

  content.appendChild(modalImg);
  modal.appendChild(closeBtn);
  modal.appendChild(content);
  modal.appendChild(caption);
  document.body.appendChild(modal);

  let previouslyFocused: Element | null = null;

  function openModal(src: string, alt: string) {
    previouslyFocused = document.activeElement;
    modalImg.src = src;
    modalImg.alt = alt;
    caption.textContent = alt;
    modal.setAttribute('data-open', '');
    document.body.style.overflow = 'hidden';
    setTimeout(() => modal.focus(), 20);
  }

  function closeModal() {
    modal.removeAttribute('data-open');
    document.body.style.overflow = '';
    // Clear src after fade-out
    setTimeout(() => {
      modalImg.src = '';
    }, 260);
    if (previouslyFocused instanceof HTMLElement) previouslyFocused.focus();
  }

  closeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    closeModal();
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal || e.target === content) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal.hasAttribute('data-open')) closeModal();
  });

  // ── Upgrade prose images ──────────────────────────────────────────────────

  const article = document.querySelector('article .prose');
  if (article) {
    const CAMERA_SVG =
      '<svg class="screenshot-trigger-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">' +
      '<path fill-rule="evenodd" d="M1 8a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 018.07 3h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0016.07 6H17a2 2 0 012 2v7a2 2 0 01-2 2H3a2 2 0 01-2-2V8zm13.5 3a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM10 14a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" /></svg>';

    article.querySelectorAll('img').forEach((imgEl) => {
      const src = imgEl.getAttribute('src');
      const alt = imgEl.getAttribute('alt') || 'Screenshot';
      if (!src) return;

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'screenshot-trigger';
      btn.setAttribute('aria-label', `View screenshot: ${alt}`);

      btn.innerHTML =
        CAMERA_SVG +
        '<span class="screenshot-trigger-label">Screenshot</span>';

      // Popover
      const popover = document.createElement('span');
      popover.className = 'screenshot-popover';
      popover.setAttribute('role', 'tooltip');
      popover.innerHTML =
        '<span class="screenshot-popover-inner">' +
        '<img src="' + src + '" alt="" class="screenshot-popover-img" loading="lazy" />' +
        '<span class="screenshot-popover-caption">' + alt + '</span>' +
        '</span>';
      btn.appendChild(popover);

      // Hover / focus → popover
      let hideTimer: ReturnType<typeof setTimeout>;

      function showPop() {
        clearTimeout(hideTimer);
        const rect = btn.getBoundingClientRect();
        if (rect.top < 260) {
          btn.setAttribute('data-pop-below', '');
        } else {
          btn.removeAttribute('data-pop-below');
        }
        btn.setAttribute('data-pop-open', '');
      }

      function hidePop() {
        hideTimer = setTimeout(() => btn.removeAttribute('data-pop-open'), 80);
      }

      btn.addEventListener('mouseenter', showPop);
      btn.addEventListener('mouseleave', hidePop);
      btn.addEventListener('focus', showPop);
      btn.addEventListener('blur', hidePop);

      // Click → modal (Enter/Space fire click on <button> automatically)
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        openModal(src, alt);
      });

      // Replace in DOM — keep <p> wrapper when the image is the sole content
      const parent = imgEl.parentElement;
      if (parent?.tagName === 'P') {
        const significant = Array.from(parent.childNodes).filter(
          (n) => !(n.nodeType === Node.TEXT_NODE && (n as Text).data.trim() === '')
        );
        if (significant.length === 1) {
          parent.classList.add('screenshot-trigger-para');
          parent.innerHTML = '';
          parent.appendChild(btn);
          return;
        }
      }
      imgEl.replaceWith(btn);
    });
  }
</script>
